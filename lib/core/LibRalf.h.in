#pragma once

#define LIBRALF_VERSION_MAJOR @RALF_UTILS_VERSION_MAJOR@
#define LIBRALF_VERSION_MINOR @RALF_UTILS_VERSION_MINOR@
#define LIBRALF_VERSION_MICRO @RALF_UTILS_VERSION_MICRO@

#define LIBRALF_VERSION_STRING "@RALF_UTILS_VERSION_STRING@"

#define LIBRALF_VERSION LIBRALF_VERSION_CHECK(LIBRALF_VERSION_MAJOR, LIBRALF_VERSION_MINOR, LIBRALF_VERSION_MICRO)

#define LIBRALF_VERSION_CHECK(major, minor, micro) (((major) << 16) | ((minor) << 8) | (micro))


#if defined(_WIN32) || defined(_WIN64) || defined(__CYGWIN__)
#    if defined(__LIBRALF_BUILD)
#        define LIBRALF_EXPORT __declspec(dllexport)
#    else
#        define LIBRALF_EXPORT __declspec(dllimport)
#    endif
#else
#    define LIBRALF_EXPORT __attribute__((visibility("default")))
#endif

#define LIBRALF_NS entos::ralf

namespace LIBRALF_NS
{

    // -------------------------------------------------------------------------
    /*!
        \fn libRalfVersionMajor
        \fn libRalfVersionMinor
        \fn libRalfVersionMicro

        Returns the major, minor and micro version numbers of the libRalf library.

     */
    LIBRALF_EXPORT int libRalfVersionMajor();
    LIBRALF_EXPORT int libRalfVersionMinor();
    LIBRALF_EXPORT int libRalfVersionMicro();

    // -------------------------------------------------------------------------
    /*!
        \fn libRalfVersionString

        Returns the version string of the libRalf library.  This will typically
        be the major.minor.micro version numbers concatenated together, with any
        additional suffixes for pre-release versions.

     */
    LIBRALF_EXPORT const char *libRalfVersionString();

} // namespace LIBRALF_NS
